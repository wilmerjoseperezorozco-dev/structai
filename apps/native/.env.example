EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# apps/api corriendo local (uvicorn). NO uses localhost si pruebas en un
# dispositivo físico — usa la IP LAN de esta máquina (ej. 192.168.1.X:8000).
# Para emulador Android usa 10.0.2.2:8000. Para simulador iOS, localhost:8000 sí funciona.
EXPO_PUBLIC_API_URL=http://localhost:8000
